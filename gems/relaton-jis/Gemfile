# frozen_string_literal: true

source "https://rubygems.org"

# Specify your gem's dependencies in relaton_jis.gemspec
gemspec

# Use local monorepo sibling gems where available.
Dir["../*/"].each do |dir|
  name = File.basename(dir)
  next if name == File.basename(__dir__)
  next unless File.exist?(File.join(dir, "#{name}.gemspec"))
  gem name, path: dir
end

# pubid 2.x is unpublished; the RubyGems 2.0.0.pre.alpha.2 build predates the
# current lutaml-model and its `from_hash` is broken (index-v2 consumption needs
# it). Track the lutaml-model branch, matching relaton-data-jis. Override to a
# local checkout with `bundle config set local.pubid /path/to/pubid`.
gem "pubid", git: "https://github.com/metanorma/pubid.git",
             branch: "rt-new-lutaml-model"

gem "rake", "~> 13.0"
gem "rspec", "~> 3.0"

gem "rubocop", "~> 1.48"
gem "rubocop-performance", "~> 1.11"
gem "rubocop-rails", "~> 2.12"


gem "equivalent-xml", "~> 0.6"
gem "ruby-jing"
gem "simplecov", "~> 0.21"
gem "vcr", "~> 6.0"
gem "webmock", "~> 3.0"
