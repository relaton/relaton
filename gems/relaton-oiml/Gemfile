# frozen_string_literal: true

source "https://rubygems.org"

# Specify your gem's dependencies in relaton-oiml.gemspec
gemspec

# Use local monorepo sibling gems where available.
Dir["../*/"].each do |dir|
  name = File.basename(dir)
  next if name == File.basename(__dir__)
  next unless File.exist?(File.join(dir, "#{name}.gemspec"))
  gem name, path: dir
end

# TEMPORARY: relaton-data-oiml's index-v2 uses the new pubid lutaml-model
# serialization, which the released pubid (~> 2.0.0.pre.alpha.3 on rubygems)
# cannot deserialize. Track the unreleased branch until that work ships, then
# drop this line (the gemspec keeps the released `~> 2.0.0.pre.alpha.3` pin).
gem "pubid", git: "https://github.com/metanorma/pubid", branch: "rt-new-lutaml-model"

gem "byebug"
gem "equivalent-xml", "~> 0.6"
gem "rake", "~> 13.0"
gem "rspec", "~> 3.0"
gem "ruby-jing"
gem "simplecov"
gem "vcr"
gem "webmock"
